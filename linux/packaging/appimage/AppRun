#!/bin/bash

cd "$(dirname "$0")"
export LD_LIBRARY_PATH=usr/lib

# Handles desktop integration:
# 1. Copies app icons to ~/.local/share/icons
# 2. Ensures icon theme index exists
# 3. Creates a .desktop file pointing to this AppImage
# 4. Skips if a system-wide installation (/usr/share/applications) is detected
install_integration() {
    if [[ -z "$APPIMAGE" ]]; then
        return
    fi

    REAL_HOME=$(getent passwd "$USER" | cut -d: -f6)
    
    if [ -z "$REAL_HOME" ]; then
        REAL_HOME="$HOME"
    fi

    APP_NAME="hiddify"
    TARGET_DESKTOP="$REAL_HOME/.local/share/applications/hiddify.desktop"
    LOCAL_HICOLOR="$REAL_HOME/.local/share/icons/hicolor"
    
    if [ ! -f "$LOCAL_HICOLOR/index.theme" ]; then
        mkdir -p "$LOCAL_HICOLOR"
        if [ -f "/usr/share/icons/hicolor/index.theme" ]; then
            cp "/usr/share/icons/hicolor/index.theme" "$LOCAL_HICOLOR/"
        else
            echo -e "[Icon Theme]\nName=Hicolor\nDirectories=128x128/apps,256x256/apps" > "$LOCAL_HICOLOR/index.theme"
        fi
    fi

    if [[ -f "./hiddify.png" ]]; then

        mkdir -p "$LOCAL_HICOLOR/128x128/apps"
        cp "./hiddify.png" "$LOCAL_HICOLOR/128x128/apps/hiddify.png"
        
        mkdir -p "$LOCAL_HICOLOR/256x256/apps"
        cp "./hiddify.png" "$LOCAL_HICOLOR/256x256/apps/hiddify.png"
        
        gtk-update-icon-cache -f -t "$LOCAL_HICOLOR" 2>/dev/null || true
    fi

    if [ -f "/usr/share/applications/hiddify.desktop" ]; then
        return
    fi

    APP_VERSION=$(jq -r .version < "./data/flutter_assets/version.json" 2>/dev/null || grep -oP '"version":\s*"\K[^"]+' "./data/flutter_assets/version.json" 2>/dev/null || echo "1.0.0")
    mkdir -p "$(dirname "$TARGET_DESKTOP")"

    cat > "$TARGET_DESKTOP" <<EOF
[Desktop Entry]
Type=Application
Name=IRC
GenericName=IRC
GenericName[fa]=هیدیفای
Exec="$APPIMAGE"
Icon=hiddify
Terminal=false
StartupWMClass=app.hiddify.com
Comment=A multi-platform proxy client based on Sing-box universal proxy tool-chain.
Comment[fa]=یک کلاینت پروکسی چند‌سکویی بر پایه زنجیره-ابزار پروکسی همه‌منظوره سینگ-باکس.
Keywords=IRC;Proxy;VPN;V2ray;Nekoray;Xray;Psiphon;OpenVPN;AntiCensorship;
Keywords[fa]=هیدیفای;پروکسی;وی‌پی‌ان;وی۲ری;نکوباکس;ایکسری;سایفون;اوپن‌وی‌پی‌ان;فیلترشکن;
X-AppImage-Name=IRC
X-AppImage-Version=$APP_VERSION
X-AppImage-Arch=x86_64
X-AppImage-Homepage=https://github.com/manyuroff-hub/irc-app
X-AppImage-UpdateURL=https://github.com/manyuroff-hub/irc-app
EOF

    chmod +x "$TARGET_DESKTOP"
    update-desktop-database "$REAL_HOME/.local/share/applications" 2>/dev/null || true
}

# Usage info
show_help() {
cat << EOF
Usage: ${0##*/} ...
start IRC or HiddifyCli, when no parameter is given, IRC is executed.
    -v              show version
EOF
}
show_version() {
    printf "IRC version "
    jq .version <./data/flutter_assets/version.json
}
# Initialize variables:
service=0 #declare -i service
OPTIND=1

# Resetting OPTIND is necessary if getopts was used previously in the script.
# It is a good idea to make OPTIND local if you process options in a function.

# Filter out invalid environment arguments like %u before processing
CLEANED_ARGS=()
for arg in "$@"; do
    case "$arg" in
        %u|%U|%f|%F) ;; # Drop these arguments
        *) CLEANED_ARGS+=("$arg") ;;
    esac
done
set -- "${CLEANED_ARGS[@]}"

# If no arg is provided, execute hiddify app
if [[ $# == 0 ]];then 
    install_integration
    exec ./hiddify
else

# Processing arguments
    case $1 in
        HiddifyCli)  
            exec ./HiddifyCli ${@:3}
            exit 0
            ;;
        h)
            show_help
            exit 0
            ;;
        v)  show_version
            exit 0
            ;;
        *)
            # Pass deep-links or valid arguments to the UI app
            install_integration
            exec ./hiddify "$@"
            ;;
    esac
fi
